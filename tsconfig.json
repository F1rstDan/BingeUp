{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "types": ["chrome", "node", "vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "wxt.config.ts",
    "vitest.config.ts",
    ".wxt/wxt.d.ts",
    ".wxt/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", ".output"]
}
